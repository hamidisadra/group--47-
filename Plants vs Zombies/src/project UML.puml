    }

    interface IMovable {
      +move(deltaX:float) : void
    }

    abstract class GameObject {
      +positionX : float
      +positionY : int
      +health : int
      +isAlive : boolean
      --
      +takeDamage(amount:int) : void
      +die() : void
      +update(tickCount:int) : void
    }

    interface IAttacker {
      +attack(target:GameObject) : void
      +getDamage() : int
      +getRange() : int
    }

    interface ISunProducer {
      +produceSun() : int
    }

    interface IUpgradable {
      +level : int
      +upgrade() : void
    }

    interface IFreezable {
      +freeze(duration:int) : void
      +melt() : void
    }

    interface IWall {
      +block(zombie:Zombie) : void
      +getHealth() : int
    }

    interface IIceEffect {
      +chill(target:Zombie) : void
      +getSlowFactor() : float
    }

    interface IChargeable {
      +charge() : void
      +isReady() : boolean
    }

    interface IGrowable {
      +grow() : void
      +isMature() : boolean
    }

    interface IModifier {
      +modify(target:Plant) : void
    }

    interface IFireEffect {
      +burn(target:Zombie) : void
      +getBurnDamage() : int
    }

    interface IPoisonEffect {
      +poison(target:Zombie) : void
    }

    abstract class Plant {
      -health : int
      -freezeLevel : int
      -frozen : boolean
      -fireTag : boolean
      -boosted : boolean
      +id : int
      +name : String
      +cost : int
      +baseHp : int
      +currentHp : int
      +rechargeTime : float
      +actionInterval : float
      +level : int
      +cooldownRemaining : float
      +plantTags : List<PlantTag>
      +levelUpgrades : List<Upgrade>
      +type : String
      +sunCost : int
      +attackPower : int
      +location : GridPosition
      +category : PlantCategory
      +canStack : boolean
      +isBoostedByPlantFood : boolean
      --
      +takeDamage(amount : int) : void
      +addFreezeLevel() : void
      +unfreeze() : void
      +isFrozen() : boolean
      +boost() : void
      +onPlantFood() : void
      +onTick() : void
      +upgrade() : void
      +canPlantOn(tile:Tile) : boolean
      +applyPlantFoodEffect() : void
      +resetCooldown() : void
    }

    class SunProducerPlant {
      +sunAmount : int
      +productionInterval : float
      --
      +produceSun() : int
    }

    class ShooterPlant {
      +damage : int
      +projectileType : ProjectileType
      +multiShot : int
      --
      +attack(target:GameObject) : void
      +getDamage() : int
      +getRange() : int
    }

    class LobberPlant {
      +damage : int
      +splashRadius : float
      --
      +attack(target:GameObject) : void
      +getDamage() : int
      +getRange() : int
    }

    class ExplosivePlant {
      +explosionDamage : int
      +explosionRadius : float
      +instantUse : boolean
    }

    class MeleePlant {
      +attackCooldown : float
      +areaEffect : boolean
      --
      +attack(target:GameObject) : void
      +getDamage() : int
      +getRange() : int
      +charge() : void
      +isReady() : boolean
    }

    class WallPlant {
      +reflectDamage : int
      --
      +block(zombie:Zombie) : void
      +getHealth() : int
    }

    class ModifierPlant {
      +modify(target:Plant) : void
    }

    class HomingPlant {
      +targetingMode : TargetingMode
      --
      +attack(target:GameObject) : void
      +getDamage() : int
      +getRange() : int
    }

    class StrikeThroughPlant {
      +pierceCount : int
    }

    abstract class Zombie {
      -health : int
      -speed : double
      -row : int
      -col : double
      +speed : float
      +attackDamage : int
      +armor : ArmorDecorator
      +waveCost : int
      +isHypnotized : boolean
      +currentPosition : ContinuousPosition
      +lane : int
      +currentHealth : int
      +damageToPlant : int
      +abilities : List<ZombieAbility>
      +effects : List<ZombieEffect>
      +isGlowing : boolean
      +isBoss : boolean
      +initialWaveCost : int
      --
      +move() : void
      +takeDamage(amount : int) : void
      +isAlive() : boolean
      +onReachPlant(plant:Plant) : void
      +onDeath() : void
      +specialBehavior() : void
      +receiveProjectile(projectile:Projectile) : void
      +attackPlant(plant:Plant) : void
      +dropLoot() : LootType
      +isDead() : boolean
    }

    interface ZombieState {
      +handleMovement()
      +handleAttack()
    }

    interface PlantState {
      +handleAttack()
    }

    abstract class ArmorDecorator {
      +armorHp : int
      --
      +absorbDamage(amount:int) : int
    }

    class "Basic Group" as BasicGroup
    class "Heavy Group" as HeavyGroup
    class "Utility Group" as UtilityGroup
    class "Special Movement Group" as SpecialMovementGroup
    class "Special Combat Group" as SpecialCombatGroup
    class "Spawn Group" as SpawnGroup

    class Position {
        -x : double
        -y : double
        +getX() : double
        +getY() : double
        +setX(x : double) : void
        +setY(y : double) : void
        +distanceTo(p : Position) : double
    }

    class GridPosition {
      +x : int
      +y : int
    }

    class ContinuousPosition {
      +x : float
      +y : int
    }

    class TickClock {
      +ticksPerSecond : int
      +currentTick : int
      --
      +advance(count:int) : void
      +toSeconds(ticks:int) : float
      +getElapsedSeconds() : float
    }

    class TimeManager {
        -ticksPerSecond : int
        -currentTick : int
        +advanceTime(ticks : int) : void
        +spawnSun() : void
        +updateWaves() : void
        +updateEffects() : void
        +getCurrentTick() : int
    }

    class Tick {
        -value : int
        +toSeconds() : double
    }

    class GameSession {
      +status : GameStatus
      +currentSunAmount : int
      +plantFoodCount : int
      +currentWaveNumber : int
      --
      +advanceTime(count:int) : void
      +collectSun(position:GridPosition) : boolean
      +plantPlant(type:String, position:GridPosition) : boolean
      +pluckPlant(position:GridPosition) : Plant
      +feedPlant(position:GridPosition) : boolean
      +releaseNuke() : void
      +win() : void
      +lose() : void
    }

    class GameCommandController {
      --
      +advanceTime(count:int) : void
      +collectSun(x:int, y:int) : void
      +showSunAmount() : int
      +plantPlant(type:String, x:int, y:int) : void
      +pluckPlant(x:int, y:int) : void
      +feedPlant(x:int, y:int) : void
      +showMap() : String
      +showPlantsStatus() : String
      +showTileStatus(x:int, y:int) : String
      +zombiesInfo() : String
      +releaseNuke() : void
      +cheatAddSuns(count:int) : void
      +cheatAddPlantFood() : void
      +cheatRemoveCooldown() : void
      +cheatSpawnZombie(type:String, x:int, y:int) : void
    }

