        +seasonType : SeasonType
        --
        +showMap() : void
        +getTile(x : int, y : int) : Tile
        +getTile(position:GridPosition) : Tile
        +placePlant(plant : Plant, x : int, y : int) : void
        +removePlant(x : int, y : int) : void
        +getZombiesInLane(row:int) : List<Zombie>
